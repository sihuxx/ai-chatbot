# ══════════════════════════════════════════════
#  AI Chatbot - 환경변수 예시 (배포용 주석 포함)
# ══════════════════════════════════════════════

# ── Anthropic Claude API ─────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── 데이터베이스 ─────────────────────────────
# [로컬 개발] SQLite
DATABASE_URL="file:./dev.db"

# [Vercel 배포 - Turso 사용 시 아래로 교체]
# DATABASE_URL="libsql://your-db-name-username.turso.io?authToken=your-token"

# ── NextAuth ──────────────────────────────────
# 배포 시: NEXTAUTH_URL을 실제 도메인으로 변경
# 예) https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# openssl rand -base64 32  명령어로 생성 (32자 이상 랜덤 문자열)
NEXTAUTH_SECRET=change-me-to-a-random-string-32-chars

# ── 챗봇 설정 ─────────────────────────────────
CHATBOT_MAX_TOKENS=2048
CHATBOT_TEMPERATURE=0.7
CHATBOT_MODEL=claude-sonnet-4-20250514

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_GUEST_PER_SESSION=20
RATE_LIMIT_USER_PER_DAY=50
